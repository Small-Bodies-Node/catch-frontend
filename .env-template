# === Dev API server ===
# Development API runs on a fixed port 3000 (not configurable via env). See src/server/local.api.ts and proxy.conf.json

# === Production SSR server ===
# Port for the SSR server (read by src/server.ts as process.env.PORT). _pm2 sources this file and passes env to Node.
# Uncomment and set to override default 4000
# PORT=4000

# === Runtime site banner ===
# Set a message to show a temporary banner under the site header. Leave empty to hide it.
# Example: CATCH_SITE_BANNER_MESSAGE='ATLAS data not available until 2026-07-01 18:00 UTC'
CATCH_SITE_BANNER_MESSAGE=''

# Banner level is only severity. Supported values: info, warning, error.
CATCH_SITE_BANNER_LEVEL='warning'

# Optional ISO-ish start time. If set and still future, the banner is hidden.
# This start/expiry window also applies to CATCH_DATA_ACCESS_DISABLED.
CATCH_SITE_BANNER_STARTS_AT=''

# Optional ISO-ish expiry time. If set and already past, the banner is hidden.
CATCH_SITE_BANNER_EXPIRES_AT=''

# Set true to disable searches and redirect direct /data visits to the homepage.
CATCH_DATA_ACCESS_DISABLED='false'

# === PM2 (optional, used by ./_pm2 wrapper) ===
# Name of the pm2 process (default used by _pm2: NG20)
# PM2_APP_NAME=NG20

# Number of days to retain logs via pm2-logrotate (default used by _pm2: 14)
# PM2_LOG_RETENTION_DAYS=14

# Optional absolute path to the node binary if not on PATH (e.g., /usr/bin/node)
# PM2_NODE_PATH=/usr/bin/node

# Entry file for production SSR server (default used by _pm2: dist/catch-frontend-ng20/server/server.mjs)
# PM2_START_FILE=dist/catch-frontend-ng20/server/server.mjs

# === CAT API ===
# Base URL for the CAT data API. Browser builds currently read the matching CAT_BASE_URL value from src/environments/*.
CAT_BASE_URL='http://sbn-cat-alb-2030771433.us-west-2.elb.amazonaws.com'


AWS_ACCESS_KEY_ID=''
AWS_SECRET_ACCESS_KEY=''
AWS_REGION='us-east-1'
S3_BUCKET_NAME=''
S3_BUCKET_BASE_URL=''
